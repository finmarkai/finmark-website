# Netlify redirects
# https://docs.netlify.com/routing/redirects/
#
# 301 redirects from the old multi-pillar site (Sprint 1 + 2) to the
# refocused AP-only site. Preserves any link equity Google has assigned
# to the old URLs and prevents 404s for anyone with old bookmarks.
#
# Format: from  to  status
# (note: paths are space-separated, NOT slash-separated)

# Old pillar URLs → AP pillar
/ai-financial-automation                              /accounts-payable-automation              301
/compliance-automation                                /accounts-payable-automation              301
/ai-fraud-detection                                   /accounts-payable-automation              301
/payment-processing-automation                        /accounts-payable-automation              301
/ai-financial-reporting                               /accounts-payable-automation              301
/unified-financial-data-platform                      /accounts-payable-automation              301
/predictive-financial-forecasting                     /accounts-payable-automation              301
/financial-workflow-automation                        /accounts-payable-automation              301

# Old cluster URLs that map naturally to a new AP cluster → that cluster
/payment-processing-automation/accounts-payable-automation   /accounts-payable-automation/ap-automation-software   301
/payment-processing-automation/automated-payment-processing  /accounts-payable-automation/vendor-payment-automation  301

# All remaining old cluster URLs → AP pillar (catches the long tail)
/ai-financial-automation/*                            /accounts-payable-automation              301
/compliance-automation/*                              /accounts-payable-automation              301
/ai-fraud-detection/*                                 /accounts-payable-automation              301
/payment-processing-automation/*                      /accounts-payable-automation              301
/ai-financial-reporting/*                             /accounts-payable-automation              301
/unified-financial-data-platform/*                    /accounts-payable-automation              301
/predictive-financial-forecasting/*                   /accounts-payable-automation              301
/financial-workflow-automation/*                      /accounts-payable-automation              301
